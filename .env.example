# ============================================
# Crypto Predict MLOps - Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# --- API Keys ---
COINGECKO_API_KEY=CG-your_api_key_here

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=crypto_predict
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_strong_password_here

# --- MongoDB ---
MONGO_URI=mongodb://crypto_app:crypto_app_pwd@localhost:27017/crypto_predict
MONGO_DB=crypto_predict
MONGO_ROOT_USER=mongo_admin
MONGO_ROOT_PASSWORD=your_mongo_root_password_here

# --- Airflow ---
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=your_airflow_password_here
